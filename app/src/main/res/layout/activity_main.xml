<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#000000"
    android:layout_height="match_parent"
    android:layout_width="match_parent">

    <LinearLayout
        android:id="@+id/layoutInicio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Header com o Ícone e Nome do App -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/app_logo"
                android:contentDescription="Ícone do App"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flyer Media Player"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnIniciar"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_iniciar_bg"
            app:backgroundTint="@null"
            android:focusable="true"
            android:paddingVertical="16dp"
            android:paddingHorizontal="24dp"
            android:text="INICIAR SISTEMA"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnConfiguracoes"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/btn_config_bg"
            app:backgroundTint="@null"
            android:focusable="true"
            android:paddingVertical="14dp"
            android:paddingHorizontal="24dp"
            android:text="CONFIGURAÇÕES"
            android:textColor="#F1F5F9"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Rodapé do Desenvolvedor -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Criado por Rodrigo Vernaschi"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:layout_marginEnd="10dp" />

            <ImageView
                android:id="@+id/btnGithub"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_github"
                android:contentDescription="GitHub"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/btnInstagram"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_instagram"
                android:contentDescription="Instagram"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/loadingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:resize_mode="fit"
        app:surface_type="surface_view"
        app:use_controller="false" />

    <ProgressBar
        android:id="@+id/progressBarVideo"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_gravity="bottom"
        android:progressDrawable="@android:drawable/progress_horizontal"
        android:progressTint="#FF0000"
        android:visibility="gone" />

    <!-- PAINEL DE CONFIGURAÇÕES -->
    <LinearLayout
        android:id="@+id/layoutSettingsContainer"
        android:layout_width="400dp"
        android:layout_height="match_parent"
        android:layout_marginVertical="12dp"
        android:layout_gravity="center"
        android:background="#EE111111"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configurações"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- CONTEÚDO ROLÁVEL DAS CONFIGURAÇÕES -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Iniciar com a TV Box"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:focusable="true"
                    android:focusedByDefault="true"
                    android:padding="6dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchIntercalarPrincipais"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="INTERCALAR VÍDEOS PRINCIPAIS"
                    android:textColor="#00E676"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:layout_marginTop="6dp"
                    android:padding="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Quando há múltiplos vídeos principais no dispositivo"
                    android:textColor="#BBFFFFFF"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp" />

                <!-- MODO ATRAÇÃO -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#44FFFFFF"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchModoAtracao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MODO ATRAÇÃO"
                    android:textColor="#FFD700"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:padding="6dp" />

                <LinearLayout
                    android:id="@+id/layoutModoAtracaoCampos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vídeo ou Caminho da Atração:"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Digite o nome do vídeo ou o caminho (ex: GRUPO XXX ou PASTA/GRUPO XXX)"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/editVideoAtracao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#22FFFFFF"
                        android:hint="Ex: GRUPO REVELACAO"
                        android:textColorHint="#88FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:padding="8dp"
                        android:inputType="textCapCharacters"
                        android:imeOptions="actionDone"
                        android:singleLine="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Qtd. de vídeos da atração por bloco:"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/editQtdAtracao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#22FFFFFF"
                        android:hint="Ex: 1"
                        android:textColorHint="#88FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:padding="8dp"
                        android:inputType="number"
                        android:imeOptions="actionDone"
                        android:singleLine="true"
                        android:focusable="true" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchTocarAleatoriosAtracao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TOCAR VÍDEOS ALEATÓRIOS"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:focusable="true"
                        android:layout_marginTop="10dp"
                        android:padding="6dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#44FFFFFF"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp" />

                <!-- Nome / palavra-chave do vídeo principal -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Palavra-chave do vídeo principal\n(separe com vírgula para mais de uma palavra-chave):"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editNomeMaria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#22FFFFFF"
                    android:hint="Ex: MARIA, promo, grupo_da_semana"
                    android:textColorHint="#88FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:padding="8dp"
                    android:inputType="textCapCharacters"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:focusable="true" />

                <!-- Nome da pasta dos vídeos aleatórios -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pasta dos vídeos aleatórios:"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editPastaAleatorios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#22FFFFFF"
                    android:hint="Ex: VIDEOS"
                    android:textColorHint="#88FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:padding="8dp"
                    android:inputType="textCapCharacters"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:focusable="true" />

                <!-- Qtd de vídeos principais por bloco -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Qtd. de vídeos principais por bloco:"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editQtdMaria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#22FFFFFF"
                    android:hint="Ex: 1"
                    android:textColorHint="#88FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:padding="8dp"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:focusable="true" />

                <!-- Qtd de vídeos aleatórios por bloco -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Qtd. de vídeos aleatórios por bloco:"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editQtdAleatorios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#22FFFFFF"
                    android:hint="Ex: 2"
                    android:textColorHint="#88FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:padding="8dp"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:focusable="true" />

                <!-- Tempo máximo por vídeo aleatório (em minutos) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tempo máx. vídeo aleatório (minutos):"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editTempoMaxMinutos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#22FFFFFF"
                    android:hint="Ex: 8"
                    android:textColorHint="#88FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:padding="8dp"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:focusable="true" />
            </LinearLayout>
        </ScrollView>

        <!-- BARRA FIXA DE BOTÕES INFERIORES DA CONFIG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnSalvarSettings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/btn_iniciar_bg"
                app:backgroundTint="@null"
                android:focusable="true"
                android:paddingVertical="12dp"
                android:text="SALVAR"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFecharSettings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/btn_fechar_bg"
                app:backgroundTint="@null"
                android:focusable="true"
                android:paddingVertical="12dp"
                android:text="FECHAR"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- MODAL DE CONFIRMAÇÃO / DIAGNÓSTICO DO SCAN -->
    <LinearLayout
        android:id="@+id/layoutModalConfirmacao"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#FA1A1A1A"
        android:elevation="10dp"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/txtTituloModal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verificação dos Arquivos"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/txtMensagemModal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resultado do teste no USB..."
            android:textColor="#DDDDDD"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <ProgressBar
            android:id="@+id/loadingBarModal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutBotoesModal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnSalvarMesmoAssimModal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#2E7D32"
                android:focusable="true"
                android:text="Salvar Mesmo Assim"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnFecharModal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:backgroundTint="#C62828"
                android:focusable="true"
                android:text="FECHAR"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>